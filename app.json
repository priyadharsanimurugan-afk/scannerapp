{
  "expo": {
    "name": "CardScan Pro",
    "slug": "CardScannerPro",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/scannerlogo.png",
    "scheme": "cardscanner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cardscanner.realtime",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera to scan business cards",
        "NSPhotoLibraryUsageDescription": "Allow access to photos to scan business cards",
        "NSPhotoLibraryAddUsageDescription": "Allow saving scanned images"
      }
    },

    "android": {
      "package": "com.cardscanner.realtime",
      "softwareKeyboardLayoutMode": "pan",
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/scannerlogo.png",
        "backgroundColor": "#0F1F3D"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/scannerlogo.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera to scan business cards"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow photo access to scan cards"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/scannerlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "2bf15862-7ce1-4526-9d40-ae194994b092"
      }
    },

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/2bf15862-7ce1-4526-9d40-ae194994b092"
    }
  }
}
