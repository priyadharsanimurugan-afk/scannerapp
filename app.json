{
  "expo": {
    "name": "CardScan Pro",
    "slug": "BusinessCardScanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/scannerlogo.png",
    "scheme": "Scannify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.priyachithra.BusinessCardScanner",
      "softwareKeyboardLayoutMode": "pan",
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/scannerlogo.png",
        "backgroundColor": "#0F1F3D"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/scannerlogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera to scan business cards"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow photo access to scan cards"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/scannerlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "23d006ed-f099-4afc-9292-2f187e234ab7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "owner": "priya077"
  }
}